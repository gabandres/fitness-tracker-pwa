{
  "name": "fitness-tracker-pwa",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && node scripts/prerender-seo.mjs && node scripts/sentry-release.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ledger": "firebase emulators:exec --only firestore \"vitest run --config vitest.ledger.config.ts\"",
    "test:rules": "npm --prefix functions run test:rules"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@macrolog/core": "*",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@google/genai": "^1.48.0",
    "@jsverse/transloco": "^8.3.0",
    "@sentry/angular": "^10.48.0",
    "firebase": "^12.11.0",
    "lucide-angular": "^1.0.0",
    "marked": "^17.0.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@jsverse/transloco-keys-manager": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
