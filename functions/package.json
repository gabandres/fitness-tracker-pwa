{
  "name": "macrolog-functions",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.config.ts\""
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.0",
    "@google/genai": "^1.48.0"
  },
  "devDependencies": {
    "typescript": "~5.9.0",
    "vitest": "^4.0.8",
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.11.0"
  }
}
