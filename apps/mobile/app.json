{
  "expo": {
    "name": "Ignia",
    "slug": "macro-log",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ignia",
    "userInterfaceStyle": "light",
    "backgroundColor": "#faf9f6",
    "ios": {
      "bundleIdentifier": "fit.ignia.app",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.fit.ignia.app"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "fit.ignia.app"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fit.ignia.app",
      "adaptiveIcon": {
        "backgroundColor": "#f2ead7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.WRITE_WEIGHT",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.WRITE_SLEEP",
        "android.permission.health.READ_HYDRATION",
        "android.permission.health.WRITE_HYDRATION",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.WRITE_BODY_FAT",
        "android.permission.health.READ_NUTRITION",
        "android.permission.health.WRITE_NUTRITION",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf9f6",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 100
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Ignia uses the camera to scan food barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ignia uses your photo library only if you choose a meal photo to log.",
          "cameraPermission": "Ignia uses the camera to scan food barcodes."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.647810616435-66v806q2ptpso47ldcgq7h3bdq6h327j"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Ignia reads your weight, sleep and water from Apple Health so you don't have to re-type them.",
          "NSHealthUpdateUsageDescription": "Ignia writes the weight, sleep, water and meals you log to Apple Health.",
          "background": false
        }
      ],
      "react-native-health-connect",
      "@bacons/apple-targets",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Today",
              "label": "Ignia — Today",
              "description": "Calories and protein left today.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "./plugins/withModularHeaders"
    ],
    "extra": {
      "googleAuth": {
        "iosClientId": "647810616435-66v806q2ptpso47ldcgq7h3bdq6h327j.apps.googleusercontent.com",
        "androidClientId": "647810616435-pg0gel6i707c8md797jlrsnu9ojmib38.apps.googleusercontent.com",
        "webClientId": "647810616435-jkiccn16plimkv9smp7ki8m90ghhocsh.apps.googleusercontent.com"
      },
      "microsoftAuth": {
        "clientId": "80eaaf29-9de3-4912-a08a-7f0c6009e310"
      },
      "router": {},
      "eas": {
        "projectId": "d0ccbe2d-b0f1-4333-9e2d-a02a21b23854"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
