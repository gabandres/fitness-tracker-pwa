{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "credentialsSource": "local"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FEATURE_PHOTO_SCAN": "0"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_FEATURE_PHOTO_SCAN": "0"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6788589414"
      }
    }
  }
}
