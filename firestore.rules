rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Actors ──────────────────────────────────────────────────
    // Verified-email gate: any provider is allowed (Google, Microsoft,
    // email+password) as long as the email has been verified. Google
    // and Microsoft return verified emails by default; password users
    // must click the verification link before they can write data.
    function isVerifiedUser() {
      return request.auth != null
          && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Admins (superuser panel). The `admin` custom claim is set by the
    // setAdminClaims Cloud Function. Admins can read pretty much anything
    // from the client for the dashboard; all MUTATIONS still go through
    // Cloud Functions so the audit log + validation can't be skipped.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ─── Log schema ─────────────────────────────────────────────
    // Required: calories, timestamp
    // Optional: weight, protein, carbs, fat, exerciseCompleted, mealLabel, mealType
    // Legacy (read-only, may exist on historic docs): liftCompleted, cardioCompleted
    function isValidLog(data) {
      return data.keys().hasAll(['calories', 'timestamp'])
          && data.keys().hasOnly([
              'weight', 'calories', 'timestamp',
              'protein', 'carbs', 'fat', 'exerciseCompleted',
              'liftCompleted', 'cardioCompleted',
              'mealLabel', 'mealType'
          ])
          && (!('weight' in data.keys()) ||
              (data.weight is number && data.weight > 0 && data.weight < 1000))
          && data.calories is number
          && data.calories >= 0
          && data.calories < 20000
          && data.timestamp is timestamp
          // Optional fields validated when present
          && (!('protein' in data.keys()) ||
              (data.protein is number && data.protein >= 0 && data.protein < 1000))
          && (!('carbs' in data.keys()) ||
              (data.carbs is number && data.carbs >= 0 && data.carbs < 1000))
          && (!('fat' in data.keys()) ||
              (data.fat is number && data.fat >= 0 && data.fat < 1000))
          && (!('exerciseCompleted' in data.keys()) ||
              data.exerciseCompleted is bool)
          && (!('liftCompleted' in data.keys()) ||
              data.liftCompleted is bool)
          && (!('cardioCompleted' in data.keys()) ||
              data.cardioCompleted is bool)
          && (!('mealLabel' in data.keys()) ||
              (data.mealLabel is string && data.mealLabel.size() <= 100))
          && (!('mealType' in data.keys()) ||
              data.mealType in ['breakfast', 'lunch', 'dinner', 'snack']);
    }

    // ─── Profile schema ─────────────────────────────────────────
    function hasProfileBase(data) {
      return data.keys().hasAll(['email', 'createdAt', 'lastSeenAt', 'profileCompleted'])
          && data.email is string
          && data.createdAt is timestamp
          && data.lastSeenAt is timestamp
          && data.profileCompleted is bool;
    }

    function isValidProfileInitial(data) {
      return data.keys().hasOnly([
              'email', 'createdAt', 'lastSeenAt', 'profileCompleted',
              // Referral attribution may be present on initial profile
              // create when the user signed up via a friend's ?ref= link.
              // compedUntil + referralRewardGrantedAt are server-only;
              // listed so server-side admin SDK writes still pass keys
              // validation if they merge during early lifecycle.
              'referredBy', 'compedUntil', 'referralRewardGrantedAt',
              // Public profile fields are server-stamped by claimPublicSlug;
              // listed so client reads-then-merges round-trip cleanly.
              'publicSlug', 'publicProfileEnabled', 'publicDisplayName',
              // Weekly digest opt-in (client-writable) + server stamp
              // (server-only, listed for round-trip parity).
              'weeklyDigestOptIn', 'lastWeeklyDigestSentAt',
              // Unit system (food-search portion picker default).
              'unitSystem',
              // Per-user suppress list for the entry-sheet recents row.
              'hiddenRecentLabels'
          ])
          && hasProfileBase(data)
          && data.profileCompleted == false
          && (!('referredBy' in data.keys()) ||
              (data.referredBy is string && data.referredBy.size() >= 20 && data.referredBy.size() <= 40))
          && (!('compedUntil' in data.keys()) || data.compedUntil is timestamp)
          && (!('referralRewardGrantedAt' in data.keys()) || data.referralRewardGrantedAt is timestamp)
          && (!('unitSystem' in data.keys()) ||
              data.unitSystem == 'us' || data.unitSystem == 'metric')
          && (!('hiddenRecentLabels' in data.keys()) ||
              (data.hiddenRecentLabels is list
               && data.hiddenRecentLabels.size() <= 200));
    }

    // ─── Measurement schema ─────────────────────────────────────
    function isValidMeasurement(data) {
      return data.keys().hasAll(['timestamp'])
          && data.keys().hasOnly(['timestamp', 'waist', 'chest', 'bicep', 'hip', 'neck'])
          && data.timestamp is timestamp
          && data.keys().size() >= 2
          && (!('waist' in data.keys()) || (data.waist is number && data.waist > 0 && data.waist < 200))
          && (!('chest' in data.keys()) || (data.chest is number && data.chest > 0 && data.chest < 200))
          && (!('bicep' in data.keys()) || (data.bicep is number && data.bicep > 0 && data.bicep < 200))
          && (!('hip' in data.keys()) || (data.hip is number && data.hip > 0 && data.hip < 200))
          && (!('neck' in data.keys()) || (data.neck is number && data.neck > 0 && data.neck < 200));
    }

    // ─── Preset schema ────────────────────────────────────────
    function isValidPreset(data) {
      return data.keys().hasAll(['name', 'calories'])
          && data.keys().hasOnly(['name', 'calories', 'protein', 'carbs', 'fat'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.calories is number
          && data.calories >= 0
          && data.calories < 20000
          && (!('protein' in data.keys()) ||
              (data.protein is number && data.protein >= 0 && data.protein < 1000))
          && (!('carbs' in data.keys()) ||
              (data.carbs is number && data.carbs >= 0 && data.carbs < 1000))
          && (!('fat' in data.keys()) ||
              (data.fat is number && data.fat >= 0 && data.fat < 1000));
    }

    // ─── Workout schemas ────────────────────────────────────────
    // Owner-scoped data with deeply-nested set/exercise arrays. We
    // validate top-level scalars, list-size caps, and string caps to
    // bound abuse, but trust the owner for nested array contents (same
    // single-user trust model as measurements). All three docs carry
    // server-assigned createdAt/updatedAt; on a merge update,
    // request.resource.data is the POST-write doc so the required
    // stamps remain present and the same validator covers update.
    function isValidExercise(data) {
      return data.keys().hasOnly(['name', 'muscles', 'defaultCues', 'logStyle', 'seedKey', 'createdAt'])
          && data.keys().hasAll(['name', 'createdAt'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.createdAt is timestamp
          && (!('muscles' in data.keys()) ||
              (data.muscles is list && data.muscles.size() <= 12))
          && (!('defaultCues' in data.keys()) ||
              (data.defaultCues is list && data.defaultCues.size() <= 30))
          && (!('logStyle' in data.keys()) ||
              (data.logStyle in ['weight-reps', 'bodyweight', 'time']))
          && (!('seedKey' in data.keys()) ||
              (data.seedKey is string && data.seedKey.size() <= 100));
    }

    function isValidWorkoutTemplate(data) {
      return data.keys().hasOnly([
              'name', 'notes', 'restMiniSec', 'restClusterSec',
              'exercises', 'seedKey', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasAll(['name', 'exercises', 'createdAt', 'updatedAt'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.exercises is list && data.exercises.size() <= 40
          && data.createdAt is timestamp && data.updatedAt is timestamp
          && (!('notes' in data.keys()) ||
              (data.notes is string && data.notes.size() <= 2000))
          && (!('restMiniSec' in data.keys()) ||
              (data.restMiniSec is number && data.restMiniSec >= 0 && data.restMiniSec <= 3600))
          && (!('restClusterSec' in data.keys()) ||
              (data.restClusterSec is number && data.restClusterSec >= 0 && data.restClusterSec <= 3600))
          && (!('seedKey' in data.keys()) ||
              (data.seedKey is string && data.seedKey.size() <= 100));
    }

    function isValidWorkoutSession(data) {
      return data.keys().hasOnly([
              'status', 'templateId', 'templateName', 'timestamp',
              'bodyweight', 'sleepHours', 'durationMin',
              'exercises', 'nextNotes', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasAll(['status', 'timestamp', 'exercises', 'createdAt', 'updatedAt'])
          && (data.status == 'active' || data.status == 'completed')
          && data.timestamp is timestamp
          && data.exercises is list && data.exercises.size() <= 40
          && data.createdAt is timestamp && data.updatedAt is timestamp
          && (!('templateId' in data.keys()) ||
              (data.templateId is string && data.templateId.size() <= 100))
          && (!('templateName' in data.keys()) ||
              (data.templateName is string && data.templateName.size() <= 100))
          && (!('bodyweight' in data.keys()) ||
              (data.bodyweight is number && data.bodyweight > 0 && data.bodyweight < 1000))
          && (!('sleepHours' in data.keys()) ||
              (data.sleepHours is number && data.sleepHours >= 0 && data.sleepHours <= 24))
          && (!('durationMin' in data.keys()) ||
              (data.durationMin is number && data.durationMin >= 0 && data.durationMin <= 1440))
          && (!('nextNotes' in data.keys()) ||
              (data.nextNotes is string && data.nextNotes.size() <= 2000));
    }

    function hasValidActivityLevel(data) {
      return data.activityLevel == 'sedentary'
          || data.activityLevel == 'light'
          || data.activityLevel == 'moderate'
          || data.activityLevel == 'active'
          || data.activityLevel == 'very_active';
    }

    function hasValidPace(data) {
      // Continuous lb/week in [0, 2] (slider, 0.1 precision). Widened from
      // the old discrete {0,0.5,1,1.5,2} set so a lean cut can sit at e.g.
      // 0.9 lb/wk. Client clamps via clampCutPace; this is the server guard.
      return data.targetPaceLbsPerWeek is number
          && data.targetPaceLbsPerWeek >= 0
          && data.targetPaceLbsPerWeek <= 2;
    }

    function hasValidGoalDirection(data) {
      return data.goalDirection == 'lose'
          || data.goalDirection == 'maintain'
          || data.goalDirection == 'gain';
    }

    function isValidProfileCompleted(data) {
      return data.keys().hasOnly([
              'email', 'createdAt', 'lastSeenAt', 'profileCompleted',
              'heightIn', 'age', 'sex', 'activityLevel',
              'targetPaceLbsPerWeek', 'goalWeightLbs',
              'travelMode', 'fastStartedAt', 'webhookApiKey',
              'fcmToken', 'reminderHour', 'timezoneOffsetMin',
              'ageConfirmedAt', 'preferredLocale', 'welcomeEmailSentAt',
              // v2 2-question onboarding (Q10): heuristic targets +
              // goal direction + onboarding stamp.
              'goalDirection', 'targetWeightLbs',
              'manualCaloriesTarget', 'manualProteinTarget',
              // Personal protein basis (g/kg), dialed in settings / refine.
              'proteinPerKg',
              'onboardingV2CompletedAt',
              // Day-3 "Refine targets" stamp.
              'targetsRefinedAt',
              // Day-3 coach push one-shot latch (set by Cloud Function
              // via admin SDK; clients only ever read, never write —
              // but admin-SDK writes still satisfy `hasOnly` so list it).
              'dayThreeCoachPushSent', 'firstEntryAt',
              // Referral attribution + server-stamped reward fields.
              'referredBy', 'compedUntil', 'referralRewardGrantedAt',
              // Public profile (server-stamped by claimPublicSlug).
              'publicSlug', 'publicProfileEnabled', 'publicDisplayName',
              // Weekly digest opt-in. `lastWeeklyDigestSentAt` is
              // server-stamped by sendWeeklyDigest; the rule below
              // pins it immutable to clients.
              'weeklyDigestOptIn', 'lastWeeklyDigestSentAt',
              // Unit system: 'us' (cup/tbsp default) | 'metric' (grams default).
              'unitSystem',
              // Per-user suppress list for the entry-sheet recents row.
              'hiddenRecentLabels'
          ])
          && hasProfileBase(data)
          && data.profileCompleted == true
          // The v2 2-Q onboarding writes profileCompleted=true with
          // ONLY base + manual targets — no Mifflin-St Jeor inputs
          // (heightIn/age/sex/activityLevel/pace). The Day-3 refine
          // sheet adds those later. So the strict-validation branch
          // only kicks in when those fields are present; the loose
          // branch accepts the v2-only shape.
          && (
            // Strict branch: full Mifflin-St Jeor profile present.
            (
              'heightIn' in data.keys()
              && data.heightIn is number && data.heightIn >= 40 && data.heightIn <= 96
              && data.age is number && data.age >= 13 && data.age <= 120
              && (data.sex == 'male' || data.sex == 'female')
              && hasValidActivityLevel(data)
              && hasValidPace(data)
            )
            // Loose branch: v2 2-Q onboarding only.
            || (
              !('heightIn' in data.keys())
              && 'manualCaloriesTarget' in data.keys()
              && data.manualCaloriesTarget is number
              && data.manualCaloriesTarget > 0
              && data.manualCaloriesTarget < 20000
            )
          )
          && (!('goalDirection' in data.keys()) || hasValidGoalDirection(data))
          && (!('targetWeightLbs' in data.keys()) ||
              (data.targetWeightLbs is number && data.targetWeightLbs > 0 && data.targetWeightLbs < 1000))
          && (!('manualCaloriesTarget' in data.keys()) ||
              (data.manualCaloriesTarget is number && data.manualCaloriesTarget > 0 && data.manualCaloriesTarget < 20000))
          && (!('manualProteinTarget' in data.keys()) ||
              (data.manualProteinTarget is number && data.manualProteinTarget > 0 && data.manualProteinTarget < 1000))
          && (!('proteinPerKg' in data.keys()) ||
              (data.proteinPerKg is number && data.proteinPerKg >= 1.6 && data.proteinPerKg <= 2.2))
          && (!('onboardingV2CompletedAt' in data.keys()) ||
              data.onboardingV2CompletedAt is timestamp)
          && (!('targetsRefinedAt' in data.keys()) ||
              data.targetsRefinedAt is timestamp)
          && (!('firstEntryAt' in data.keys()) ||
              data.firstEntryAt is timestamp)
          && (!('dayThreeCoachPushSent' in data.keys()) ||
              data.dayThreeCoachPushSent is bool)
          && (!('goalWeightLbs' in data.keys()) ||
              (data.goalWeightLbs is number && data.goalWeightLbs > 0 && data.goalWeightLbs < 1000))
          && (!('travelMode' in data.keys()) || data.travelMode is bool)
          && (!('fastStartedAt' in data.keys()) ||
              data.fastStartedAt is timestamp || data.fastStartedAt == null)
          && (!('webhookApiKey' in data.keys()) ||
              (data.webhookApiKey is string && data.webhookApiKey.size() == 36))
          && (!('fcmToken' in data.keys()) ||
              (data.fcmToken is string && data.fcmToken.size() <= 300))
          && (!('reminderHour' in data.keys()) ||
              (data.reminderHour is int && data.reminderHour >= 0 && data.reminderHour <= 23))
          && (!('timezoneOffsetMin' in data.keys()) ||
              (data.timezoneOffsetMin is int))
          && (!('ageConfirmedAt' in data.keys()) ||
              data.ageConfirmedAt is timestamp)
          && (!('preferredLocale' in data.keys()) ||
              (data.preferredLocale is string && data.preferredLocale.size() <= 10))
          && (!('welcomeEmailSentAt' in data.keys()) ||
              data.welcomeEmailSentAt is timestamp)
          // Public profile fields. Server-stamped via claimPublicSlug;
          // type checks here defend against malformed direct writes.
          && (!('publicSlug' in data.keys()) ||
              (data.publicSlug is string && data.publicSlug.size() >= 3 && data.publicSlug.size() <= 30))
          && (!('publicProfileEnabled' in data.keys()) ||
              data.publicProfileEnabled is bool)
          && (!('publicDisplayName' in data.keys()) ||
              (data.publicDisplayName is string && data.publicDisplayName.size() <= 40))
          // Weekly digest. `weeklyDigestOptIn` is client-writable; the
          // `lastWeeklyDigestSentAt` latch is server-only (immutability
          // enforced separately on the update rule).
          && (!('weeklyDigestOptIn' in data.keys()) ||
              data.weeklyDigestOptIn is bool)
          && (!('lastWeeklyDigestSentAt' in data.keys()) ||
              data.lastWeeklyDigestSentAt is timestamp)
          && (!('unitSystem' in data.keys()) ||
              data.unitSystem == 'us' || data.unitSystem == 'metric')
          && (!('hiddenRecentLabels' in data.keys()) ||
              (data.hiddenRecentLabels is list
               && data.hiddenRecentLabels.size() <= 200));
    }

    function isValidProfile(data) {
      return isValidProfileInitial(data) || isValidProfileCompleted(data);
    }

    // ─── Per-user subtree ───────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isVerifiedUser() && isValidProfile(request.resource.data);
      allow update: if isOwner(uid) && isValidProfile(request.resource.data)
                       // Referral fields are immutable from the client:
                       //   - `referredBy` is set once on profile create
                       //     and represents an audit trail. Letting users
                       //     edit it post-create would let them re-claim
                       //     a reward by switching referrers.
                       //   - `compedUntil` and `referralRewardGrantedAt`
                       //     are server-stamped by the onSubscriptionWritten
                       //     trigger via admin SDK (which bypasses rules).
                       //     A client write here = unauthorized self-grant.
                       && (resource.data.get('referredBy', null) ==
                           request.resource.data.get('referredBy', null))
                       && (resource.data.get('compedUntil', null) ==
                           request.resource.data.get('compedUntil', null))
                       && (resource.data.get('referralRewardGrantedAt', null) ==
                           request.resource.data.get('referralRewardGrantedAt', null))
                       // publicSlug + publicProfileEnabled are server-only
                       // (set by claimPublicSlug / releasePublicSlug). A
                       // direct client write here would let users grab any
                       // slug bypassing uniqueness checks.
                       && (resource.data.get('publicSlug', null) ==
                           request.resource.data.get('publicSlug', null))
                       && (resource.data.get('publicProfileEnabled', null) ==
                           request.resource.data.get('publicProfileEnabled', null))
                       // lastWeeklyDigestSentAt is server-stamped by
                       // sendWeeklyDigest; clients read but cannot reset
                       // it (which would cause duplicate sends).
                       && (resource.data.get('lastWeeklyDigestSentAt', null) ==
                           request.resource.data.get('lastWeeklyDigestSentAt', null));

      match /dailyLogs/{logId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidLog(request.resource.data);
        allow update: if isOwner(uid) && isValidLog(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Meal presets — quick-add templates.
      match /presets/{presetId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidPreset(request.resource.data);
        allow update: if isOwner(uid) && isValidPreset(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Daily weights — one weight per calendar day.
      match /dailyWeights/{dateKey} {
        allow read:   if isOwner(uid) || isAdmin();
        allow write:  if isOwner(uid)
            && request.resource.data.keys().hasAll(['weight'])
            && request.resource.data.keys().hasOnly(['weight'])
            && request.resource.data.weight is number
            && request.resource.data.weight > 0
            && request.resource.data.weight < 1000;
      }

      // Daily water intake — one doc per calendar day keyed by date.
      // Stored in US fluid ounces ({ flOz }) as the single source of
      // truth. Upper bound of 676 fl oz is ~5 gallons — implausible but
      // catches fat-finger data that would otherwise pollute charts.
      //
      // Legacy { ml } writes (≤ 20_000 ml ≈ 5 gal) are still accepted so
      // app clients cached from before the 2026-06 unit migration keep
      // working until they refresh. Drop the ml branch once they have.
      match /dailyWater/{dateKey} {
        allow read:   if isOwner(uid) || isAdmin();
        allow write:  if isOwner(uid)
            && (
              (request.resource.data.keys().hasOnly(['flOz'])
                && request.resource.data.flOz is number
                && request.resource.data.flOz >= 0
                && request.resource.data.flOz <= 676)
              || (request.resource.data.keys().hasOnly(['ml'])
                && request.resource.data.ml is number
                && request.resource.data.ml >= 0
                && request.resource.data.ml <= 20000)
            );
      }

      // Daily sleep — hours slept, one doc per calendar day keyed by date,
      // shape { hours }. Canonical record; the Train session sheet's sleep
      // mirrors here on finish. Range [0, 24].
      match /dailySleep/{dateKey} {
        allow read:   if isOwner(uid) || isAdmin();
        allow write:  if isOwner(uid)
            && request.resource.data.keys().hasOnly(['hours'])
            && request.resource.data.hours is number
            && request.resource.data.hours >= 0
            && request.resource.data.hours <= 24;
      }

      // Body measurements — weekly/biweekly body-comp tracking.
      match /measurements/{measurementId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidMeasurement(request.resource.data);
        allow update: if isOwner(uid) && isValidMeasurement(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Progress photos — index docs for owner-private Storage objects
      // (ADR-0010). Bytes live in Storage (storage.rules); this doc is
      // just metadata and carries NO download URL. One per local-date key.
      match /photos/{dateKey} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid)
                      && request.resource.data.storagePath is string
                      && request.resource.data.takenAt is timestamp;
        allow delete: if isOwner(uid);
      }

      // ─── Train tab (workout logging) ──────────────────────────
      // Per-user exercise catalog — the stable identity progression
      // charts aggregate over.
      match /exercises/{exerciseId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidExercise(request.resource.data);
        allow update: if isOwner(uid) && isValidExercise(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Editable workout templates (blueprints).
      match /workoutTemplates/{templateId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidWorkoutTemplate(request.resource.data);
        allow update: if isOwner(uid) && isValidWorkoutTemplate(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Logged sessions (snapshots). Live-written set-by-set while the
      // workout is in progress (status:'active') then flipped to
      // 'completed' on finish.
      match /workoutSessions/{sessionId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidWorkoutSession(request.resource.data);
        allow update: if isOwner(uid) && isValidWorkoutSession(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Weekly AI reports — cached markdown.
      // Writes are server-only: the `generateWeeklyReport` Cloud Function
      // enforces the Pro gate + rate limit and writes via admin SDK,
      // which bypasses these rules. Clients never create report docs.
      match /reports/{reportId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if false;
        allow delete: if isOwner(uid);
      }
    }

    // ─── Admin-facing collections ─────────────────────────────────
    // Audit log: written server-side via admin SDK; admins can read
    // from the client to render the audit tab. No client writes ever.
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ─── Server-side config ─────────────────────────────────────
    // Writes are still server-only (all admin mutations go through the
    // admin-ops Cloud Functions so everything is audited). Admins get
    // client read access so the admin panel can render the admins /
    // comped-friends / stats tabs without extra round-trips.
    match /config/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ─── Consultation quota (AI coach rate limit) ───────────────
    // Written by the reserveConsultation Cloud Function via the
    // admin SDK (which bypasses these rules). Clients never need
    // direct access — the callable returns remaining count in its
    // response, so we default-deny to match photoQuota. Prevents
    // any tenant-leak via doc-id guessing.
    match /consultationQuota/{quotaId} {
      allow read, write: if false;
    }

    // ─── Stripe Firebase Extension ───────────────────────────────
    // Managed by ext: firestore-stripe-payments.
    // The extension writes customer/subscription/payment records
    // under customers/{uid}. Products + prices are catalog data
    // readable by any signed-in user so they can render the price.
    match /customers/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      match /checkout_sessions/{id} {
        allow read, write: if isOwner(uid);
      }
      match /subscriptions/{id} {
        allow read: if isOwner(uid) || isAdmin();
      }
      match /payments/{id} {
        allow read: if isOwner(uid) || isAdmin();
      }
    }

    match /products/{id} {
      allow read: if request.auth != null;

      match /prices/{priceId} {
        allow read: if request.auth != null;
      }
      match /tax_rates/{taxId} {
        allow read: if request.auth != null;
      }
    }

    // ─── Public status heartbeat ────────────────────────────────
    // Written every few minutes by the `statusPulse` scheduled
    // Cloud Function (via admin SDK). The /status public page reads
    // this doc to decide the health indicator, so we allow unauth
    // reads. Writes stay server-only — no `allow write` means the
    // admin SDK path is the only way to update.
    match /status/{doc} {
      allow read: if true;
    }

    // Public stats doc (landing social proof). Written by a scheduled
    // Cloud Function via the admin SDK; readable by anyone so the
    // marketing landing can render the count without requiring auth.
    match /public/{doc} {
      allow read: if true;
    }

    // Public profile mirrors (`/u/<slug>`). Public-readable so the SPA
    // can render a transformation page without auth. Writes are blocked
    // for clients — the `onUserUpdateMirrorPublicProfile` trigger and
    // the `claimPublicSlug` callable are the only writers.
    match /publicProfiles/{slug} {
      allow read: if true;
    }
    // Slug-uniqueness ledger. Owned exclusively by `claimPublicSlug` /
    // `releasePublicSlug` callables; clients never read or write here.
    match /publicSlugs/{slug} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
