rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Single-user personal tool: only signed-in Gmail accounts
    // can read or write. Tighten further (e.g. hardcode the UID)
    // if this ever gets shared.
    function isGmailUser() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email.matches('.*@gmail[.]com$');
    }

    // Schema for a dailyLog document.
    function isValidLog(data) {
      return data.keys().hasOnly(['weight', 'calories', 'timestamp'])
          && data.weight is number
          && data.weight > 0
          && data.weight < 1000
          && data.calories is number
          && data.calories >= 0
          && data.calories < 20000
          && data.timestamp is timestamp;
    }

    match /dailyLogs/{logId} {
      allow read:   if isGmailUser();
      allow create: if isGmailUser() && isValidLog(request.resource.data);
      allow update: if isGmailUser() && isValidLog(request.resource.data);
      allow delete: if isGmailUser();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
