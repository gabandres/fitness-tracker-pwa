rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Actors ──────────────────────────────────────────────────
    // Verified-email gate: any provider is allowed (Google, Microsoft,
    // email+password) as long as the email has been verified. Google
    // and Microsoft return verified emails by default; password users
    // must click the verification link before they can write data.
    function isVerifiedUser() {
      return request.auth != null
          && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── Log schema ─────────────────────────────────────────────
    // Required: calories, timestamp
    // Optional: weight, protein, exerciseCompleted, mealLabel
    // Legacy (read-only, may exist on historic docs): liftCompleted, cardioCompleted
    function isValidLog(data) {
      return data.keys().hasAll(['calories', 'timestamp'])
          && data.keys().hasOnly([
              'weight', 'calories', 'timestamp',
              'protein', 'exerciseCompleted',
              'liftCompleted', 'cardioCompleted',
              'mealLabel'
          ])
          && (!('weight' in data.keys()) ||
              (data.weight is number && data.weight > 0 && data.weight < 1000))
          && data.calories is number
          && data.calories >= 0
          && data.calories < 20000
          && data.timestamp is timestamp
          // Optional fields validated when present
          && (!('protein' in data.keys()) ||
              (data.protein is number && data.protein >= 0 && data.protein < 1000))
          && (!('exerciseCompleted' in data.keys()) ||
              data.exerciseCompleted is bool)
          && (!('liftCompleted' in data.keys()) ||
              data.liftCompleted is bool)
          && (!('cardioCompleted' in data.keys()) ||
              data.cardioCompleted is bool)
          && (!('mealLabel' in data.keys()) ||
              (data.mealLabel is string && data.mealLabel.size() <= 100));
    }

    // ─── Profile schema ─────────────────────────────────────────
    function hasProfileBase(data) {
      return data.keys().hasAll(['email', 'createdAt', 'lastSeenAt', 'profileCompleted'])
          && data.email is string
          && data.createdAt is timestamp
          && data.lastSeenAt is timestamp
          && data.profileCompleted is bool;
    }

    function isValidProfileInitial(data) {
      return data.keys().hasOnly(['email', 'createdAt', 'lastSeenAt', 'profileCompleted'])
          && hasProfileBase(data)
          && data.profileCompleted == false;
    }

    // ─── Measurement schema ─────────────────────────────────────
    function isValidMeasurement(data) {
      return data.keys().hasAll(['timestamp'])
          && data.keys().hasOnly(['timestamp', 'waist', 'chest', 'bicep', 'hip'])
          && data.timestamp is timestamp
          && data.keys().size() >= 2
          && (!('waist' in data.keys()) || (data.waist is number && data.waist > 0 && data.waist < 200))
          && (!('chest' in data.keys()) || (data.chest is number && data.chest > 0 && data.chest < 200))
          && (!('bicep' in data.keys()) || (data.bicep is number && data.bicep > 0 && data.bicep < 200))
          && (!('hip' in data.keys()) || (data.hip is number && data.hip > 0 && data.hip < 200));
    }

    // ─── Preset schema ────────────────────────────────────────
    function isValidPreset(data) {
      return data.keys().hasAll(['name', 'calories'])
          && data.keys().hasOnly(['name', 'calories', 'protein'])
          && data.name is string
          && data.name.size() > 0
          && data.name.size() <= 100
          && data.calories is number
          && data.calories >= 0
          && data.calories < 20000
          && (!('protein' in data.keys()) ||
              (data.protein is number && data.protein >= 0 && data.protein < 1000));
    }

    function hasValidActivityLevel(data) {
      return data.activityLevel == 'sedentary'
          || data.activityLevel == 'light'
          || data.activityLevel == 'moderate'
          || data.activityLevel == 'active'
          || data.activityLevel == 'very_active';
    }

    function hasValidPace(data) {
      return data.targetPaceLbsPerWeek == 0.5
          || data.targetPaceLbsPerWeek == 1.0
          || data.targetPaceLbsPerWeek == 1.5
          || data.targetPaceLbsPerWeek == 2.0;
    }

    function isValidProfileCompleted(data) {
      return data.keys().hasOnly([
              'email', 'createdAt', 'lastSeenAt', 'profileCompleted',
              'heightIn', 'age', 'sex', 'activityLevel',
              'targetPaceLbsPerWeek', 'goalWeightLbs',
              'travelMode', 'fastStartedAt', 'webhookApiKey',
              'fcmToken', 'reminderHour', 'timezoneOffsetMin'
          ])
          && hasProfileBase(data)
          && data.profileCompleted == true
          && data.heightIn is number && data.heightIn >= 40 && data.heightIn <= 96
          && data.age is number && data.age >= 13 && data.age <= 120
          && (data.sex == 'male' || data.sex == 'female')
          && hasValidActivityLevel(data)
          && hasValidPace(data)
          && (!('goalWeightLbs' in data.keys()) ||
              (data.goalWeightLbs is number && data.goalWeightLbs > 0 && data.goalWeightLbs < 1000))
          && (!('travelMode' in data.keys()) || data.travelMode is bool)
          && (!('fastStartedAt' in data.keys()) ||
              data.fastStartedAt is timestamp || data.fastStartedAt == null)
          && (!('webhookApiKey' in data.keys()) ||
              (data.webhookApiKey is string && data.webhookApiKey.size() == 36))
          && (!('fcmToken' in data.keys()) ||
              (data.fcmToken is string && data.fcmToken.size() <= 300))
          && (!('reminderHour' in data.keys()) ||
              (data.reminderHour is int && data.reminderHour >= 0 && data.reminderHour <= 23))
          && (!('timezoneOffsetMin' in data.keys()) ||
              (data.timezoneOffsetMin is int));
    }

    function isValidProfile(data) {
      return isValidProfileInitial(data) || isValidProfileCompleted(data);
    }

    // ─── Per-user subtree ───────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && isVerifiedUser() && isValidProfile(request.resource.data);
      allow update: if isOwner(uid) && isValidProfile(request.resource.data);

      match /dailyLogs/{logId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid) && isValidLog(request.resource.data);
        allow update: if isOwner(uid) && isValidLog(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Meal presets — quick-add templates.
      match /presets/{presetId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid) && isValidPreset(request.resource.data);
        allow update: if isOwner(uid) && isValidPreset(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Daily weights — one weight per calendar day.
      match /dailyWeights/{dateKey} {
        allow read:   if isOwner(uid);
        allow write:  if isOwner(uid)
            && request.resource.data.keys().hasAll(['weight'])
            && request.resource.data.keys().hasOnly(['weight'])
            && request.resource.data.weight is number
            && request.resource.data.weight > 0
            && request.resource.data.weight < 1000;
      }

      // Body measurements — weekly/biweekly body-comp tracking.
      match /measurements/{measurementId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid) && isValidMeasurement(request.resource.data);
        allow delete: if isOwner(uid);
      }

      // Weekly AI reports — cached markdown.
      match /reports/{reportId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
            && request.resource.data.keys().hasAll(['markdown', 'generatedAt'])
            && request.resource.data.keys().hasOnly(['markdown', 'generatedAt'])
            && request.resource.data.markdown is string
            && request.resource.data.markdown.size() <= 10000
            && request.resource.data.generatedAt is timestamp;
        allow delete: if isOwner(uid);
      }
    }

    // ─── Server-side config (access list for comped friends) ────
    // Read + write ONLY by Cloud Functions via admin SDK. Human edits
    // happen via the Firebase console (which also uses admin creds).
    match /config/{doc} {
      allow read, write: if false;
    }

    // ─── Consultation quota (AI coach rate limit) ───────────────
    // Written by the reserveConsultation Cloud Function via the
    // admin SDK (which bypasses these rules). Clients never need
    // direct access — the callable returns remaining count in its
    // response, so we default-deny to match photoQuota. Prevents
    // any tenant-leak via doc-id guessing.
    match /consultationQuota/{quotaId} {
      allow read, write: if false;
    }

    // ─── Stripe Firebase Extension ───────────────────────────────
    // Managed by ext: firestore-stripe-payments.
    // The extension writes customer/subscription/payment records
    // under customers/{uid}. Products + prices are catalog data
    // readable by any signed-in user so they can render the price.
    match /customers/{uid} {
      allow read: if isOwner(uid);

      match /checkout_sessions/{id} {
        allow read, write: if isOwner(uid);
      }
      match /subscriptions/{id} {
        allow read: if isOwner(uid);
      }
      match /payments/{id} {
        allow read: if isOwner(uid);
      }
    }

    match /products/{id} {
      allow read: if request.auth != null;

      match /prices/{priceId} {
        allow read: if request.auth != null;
      }
      match /tax_rates/{taxId} {
        allow read: if request.auth != null;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
